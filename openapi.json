{
  "openapi": "3.1.0",
  "info": {
    "title": "STTA-DVF API",
    "description": "API d'estimation immobiliere basee sur les donnees DVF.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "summary": "Health",
        "description": "Health check : verifie la connexion DB et PostGIS.",
        "operationId": "health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/defaults": {
      "get": {
        "summary": "Defaults",
        "description": "Retourne les coefficients par defaut (pour les sliders admin frontend).",
        "operationId": "defaults_api_v1_defaults_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/estimate": {
      "post": {
        "summary": "Estimate",
        "description": "Endpoint principal d'estimation immobiliere.",
        "operationId": "estimate_api_v1_estimate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EstimationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EstimationResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
